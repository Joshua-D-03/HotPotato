:root {
    --nexus-bg: #0d0d0d;
    --nexus-orange: #da8100;
    --electric-cyan: #00f2ff;
    --slate: #1c1c1c;
    --border: #333;
}

body {
    background-color: var(--nexus-bg);
    color: #e0e0e0;
    font-family: 'Inter', 'Segoe UI', sans-serif;
    margin: 0;
    display: flex;
    justify-content: center;
}

.nexus-container { width: 100%; max-width: 900px; padding: 40px 20px; }

/* The Electrified Potato */
.potato-stage {
    position: relative;
    width: 150px;
    height: 150px;
    margin: 0 auto 10px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.electric-potato {
    font-size: 80px;
    animation: potatoSpin 12s linear infinite;
    z-index: 2;
    filter: drop-shadow(0 0 15px var(--nexus-orange));
}

@keyframes potatoSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.glow-ring {
    position: absolute;
    width: 120px;
    height: 120px;
    border: 2px solid var(--electric-cyan);
    border-radius: 50%;
    box-shadow: 0 0 25px var(--electric-cyan);
    animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.15); opacity: 1; }
}

/* UI Elements */
.engine-core h1 { text-align: center; letter-spacing: 4px; margin: 10px 0; }
.engine-core span { color: var(--nexus-orange); }

.drop-zone {
    background: #141414;
    border: 2px dashed var(--nexus-orange);
    padding: 60px;
    text-align: center;
    margin: 30px 0;
    cursor: pointer;
    transition: 0.3s;
}

.drop-zone:hover { background: rgba(218, 129, 0, 0.05); }

.config-card {
    background: var(--slate);
    border: 1px solid var(--border);
    padding: 20px;
    flex: 1;
}

.ui-row { display: flex; gap: 20px; margin-bottom: 20px; }

.nexus-btn {
    width: 100%;
    background: var(--nexus-orange);
    color: white;
    border: none;
    padding: 20px;
    font-weight: bold;
    font-size: 1.2rem;
    cursor: pointer;
    box-shadow: 0 5px 15px rgba(0,0,0,0.4);
}

.warning-panel { color: #ff5e5e; font-size: 0.8rem; margin-top: 10px; font-weight: bold; }
.hidden { display: none; }
