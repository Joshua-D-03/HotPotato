/* General Style (ezgif-inspired) */
body {
    background-color: #f7f7f7;
    color: #333;
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
    line-height: 1.5;
}

.main-header {
    background-color: #fff;
    border-bottom: 4px solid #7a5c37; /* Potato Brown */
    padding: 20px 0;
    text-align: center;
}

.potato-icon {
    font-size: 60px;
    margin-bottom: 5px;
}

.main-header h1 {
    margin: 0;
    color: #444;
    font-size: 28px;
}

.tool-nav ul {
    list-style: none;
    padding: 0;
    margin: 15px 0 0 0;
    display: flex;
    justify-content: center;
    background: #eeeeee;
}

.tool-nav li a {
    display: block;
    padding: 10px 20px;
    text-decoration: none;
    color: #0066cc;
    font-weight: bold;
    border-right: 1px solid #ccc;
}

.tool-nav li a.active {
    background-color: #fff;
    color: #333;
}

.container {
    max-width: 800px;
    margin: 20px auto;
    background: #fff;
    border: 1px solid #ccc;
    padding: 20px;
}

.tool-box {
    border: 1px solid #ddd;
    padding: 15px;
}

.tool-title {
    margin-top: 0;
    border-bottom: 1px solid #eee;
    padding-bottom: 10px;
    color: #555;
}

.upload-area {
    border: 2px dashed #bbb;
    padding: 40px;
    text-align: center;
    margin: 20px 0;
    background: #fafafa;
}

.btn-select {
    padding: 10px 25px;
    background: #f0f0f0;
    border: 1px solid #999;
    cursor: pointer;
    font-weight: bold;
}

.settings-section {
    background: #f1f1f1;
    padding: 15px;
    border: 1px solid #ccc;
}

.settings-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 15px;
}

.btn-action {
    display: block;
    width: 100%;
    padding: 15px;
    background: #4caf50;
    color: white;
    border: none;
    font-size: 18px;
    font-weight: bold;
    cursor: pointer;
}

/* Progress & Results */
.progress-area { margin: 20px 0; }
.progress-bar { background: #ddd; height: 20px; border-radius: 10px; overflow: hidden; }
.fill { background: #4caf50; height: 100%; width: 0%; transition: 0.3s; }

.result-area {
    margin-top: 20px;
    padding: 15px;
    border: 2px solid #4caf50;
    background: #f9fff9;
}

.highlight { color: #d32f2f; font-weight: bold; font-size: 1.2rem; }
.hidden { display: none; }
.small-text { font-size: 12px; color: #777; }
