// Simulated Game Catalog from Linked Store Platforms
const gameDatabase = [
    { name: "Cyberpunk 2077", reqVram: 6, reqRam: 12 },
    { name: "Elden Ring", reqVram: 4, reqRam: 12 },
    { name: "Modern Warfare III", reqVram: 8, reqRam: 16 },
    { name: "Fortnite", reqVram: 2, reqRam: 8 }
];

let sys = { ram: 0, vram: 0 };
let selectedGame = null;
let currentMode = 'quality';
let fpsTarget = 30;

// Persistence
window.onload = () => {
    const saved = localStorage.getItem('pc_arch_sys');
    if (saved) {
        sys = JSON.parse(saved);
        document.getElementById('saved-alert').classList.remove('hidden');
        document.getElementById('saved-model-name').innerText = "Personal PC Profile";
    }
};

function startScan() {
    sys.ram = navigator.deviceMemory || 8;
    sys.vram = sys.ram * 0.25; // Integrated GPU logic
    saveAndNext();
}

function showManualForm() { document.getElementById('manual-form').classList.remove('hidden'); }

function saveManualSpec() {
    sys.ram = parseFloat(document.getElementById('m-ram').value);
    sys.vram = parseFloat(document.getElementById('m-vram').value);
    saveAndNext();
}

function saveAndNext() {
    localStorage.setItem('pc_arch_sys', JSON.stringify(sys));
    transition(1, 2);
}

function linkPlatform(plat) {
    document.getElementById('catalog-zone').classList.remove('hidden');
    searchGames(); // Show all initially
}

function searchGames() {
    const term = document.getElementById('game-search').value.toLowerCase();
    const results = document.getElementById('game-results');
    results.innerHTML = '';
    
    gameDatabase.filter(g => g.name.toLowerCase().includes(term)).forEach(game => {
        const div = document.createElement('div');
        div.className = 'game-item';
        div.innerText = game.name;
        div.onclick = () => selectGame(game);
        results.appendChild(div);
    });
}

function selectGame(game) {
    selectedGame = game;
    document.getElementById('target-game-name').innerText = game.name;
    document.getElementById('target-game-req').innerText = `Min Requirements: ${game.reqVram}GB VRAM`;
    calculateBridge();
    transition(2, 3);
}

function updateFPS(val) { 
    document.getElementById('fps-val').innerText = val; 
    fpsTarget = val; 
    calculateBridge();
}

function setMode(mode) {
    currentMode = mode;
    document.getElementById('mode-quality').classList.toggle('active', mode === 'quality');
    document.getElementById('mode-perf').classList.toggle('active', mode === 'perf');
    calculateBridge();
}

function calculateBridge() {
    if (!selectedGame) return;
    
    const vramPower = sys.vram / selectedGame.reqVram;
    const modeMult = currentMode === 'perf' ? 0.7 : 1.1;
    const fpsWeight = 30 / fpsTarget;

    let scale = (vramPower * modeMult * fpsWeight).toFixed(2);
    scale = Math.max(0.25, Math.min(1.0, scale));

    // Update UI
    document.getElementById('vram-fill').style.width = Math.min(100, (1 - vramPower) * 100) + "%";
    const status = document.getElementById('read-status');
    if (scale < 0.45) {
        status.innerText = "Critical Blur: HUD might be unreadable";
        status.style.color = "#ef4444";
    } else {
        status.innerText = "Legible: UI is clear";
        status.style.color = "#10b981";
    }
    window.finalScale = scale;
}

function downloadConfig() {
    const content = `[Architect_Bridge]\nGame=${selectedGame.name}\nResolutionScale=${window.finalScale}\nFPS_Lock=${fpsTarget}\nMode=${currentMode}`;
    const blob = new Blob([content], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${selectedGame.name.replace(/\s/g, '_')}_Optimize.ini`;
    a.click();
}

function transition(from, to) {
    document.getElementById(`step-${from}`).classList.remove('active');
    document.getElementById(`step-${to}`).classList.add('active');
}

function clearProfile() {
    localStorage.removeItem('pc_arch_sys');
    location.reload();
}
