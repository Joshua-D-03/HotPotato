<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Architect Cloud | Web Optimization Portal</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="app">
        <header>
            <h1>PC <span class="highlight">Architect</span></h1>
            <p class="subtitle">Cloud-Based Hardware Bridging</p>
            <div id="saved-alert" class="hidden">
                <span>Profile: <strong id="saved-model-name"></strong></span>
                <button class="btn-text" onclick="clearProfile()">Forget PC</button>
            </div>
        </header>

        <section id="step-1" class="view active">
            <h3>1. Identify Hardware</h3>
            <div class="choice-grid">
                <button class="choice-card" onclick="startScan()">Auto-Scan Browser</button>
                <button class="choice-card" onclick="showManualForm()">Manual Spec Entry</button>
            </div>
            <div id="manual-form" class="hidden mt-1">
                <input type="number" id="m-ram" placeholder="RAM (GB)">
                <input type="number" id="m-vram" placeholder="VRAM (GB)">
                <button class="btn-primary w-full" onclick="saveManualSpec()">Lock Hardware Profile</button>
            </div>
        </section>

        <section id="step-2" class="view">
            <h3>2. Link Platform Catalog</h3>
            <div class="platform-row">
                <button class="plat-btn steam" onclick="linkPlatform('Steam')">Link Steam</button>
                <button class="plat-btn epic" onclick="linkPlatform('Epic')">Link Epic</button>
            </div>
            
            <div id="catalog-zone" class="hidden">
                <input type="text" id="game-search" placeholder="Search your library..." onkeyup="searchGames()">
                <div id="game-results" class="results-grid"></div>
            </div>
        </section>

        <section id="step-3" class="view">
            <div class="selected-game-banner">
                <h2 id="target-game-name">Game Name</h2>
                <span id="target-game-req">Requirements: High</span>
            </div>

            <div class="strategy-zone">
                <label>Target Frame Rate: <span id="fps-val" class="highlight">30</span> FPS</label>
                <input type="range" id="fps-target" min="20" max="60" value="30" oninput="updateFPS(this.value)">
                
                <div class="toggle-group">
                    <button id="mode-quality" class="toggle-btn active" onclick="setMode('quality')">Clarity</button>
                    <button id="mode-perf" class="toggle-btn" onclick="setMode('perf')">Performance</button>
                </div>
            </div>

            <div id="readability-card" class="readability-box">
                <span id="read-status">Readability Check</span>
            </div>

            <div class="vram-monitor">
                <div class="bar-bg"><div id="vram-fill" class="bar-fill"></div></div>
            </div>

            <button class="btn-download" onclick="downloadConfig()">Generate Optimization File</button>
            <button class="btn-text" onclick="location.reload()">Back to Catalog</button>
        </section>
    </div>
    <script src="script.js"></script>
</body>
</html>
