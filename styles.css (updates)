:root {
    --bg-color: #0d1117;
    --panel-color: #161b22;
    --accent-color: #58a6ff;
    --text-main: #c9d1d9;
    --danger: #f85149;
    --success: #3fb950;
    --warning: #d29922;
}

body {
    background: var(--bg-color);
    color: var(--text-main);
    font-family: 'Inter', -apple-system, sans-serif;
    margin: 0; padding: 20px;
}

.container { max-width: 1200px; margin: 0 auto; }

header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 25px; border-bottom: 1px solid #30363d; padding-bottom: 20px;
}

h1 span { color: var(--accent-color); }

.status-badge {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;
}

.disconnected { background: rgba(248, 81, 73, 0.1); color: var(--danger); border: 1px solid var(--danger); }
.connected { background: rgba(63, 185, 80, 0.1); color: var(--success); border: 1px solid var(--success); }

.dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; }

.dashboard { display: grid; grid-template-columns: 380px 1fr; gap: 20px; }
.panel { background: var(--panel-color); border: 1px solid #30363d; border-radius: 12px; padding: 20px; }

.input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin: 15px 0; }
.input-group label { display: block; font-size: 11px; color: #8b949e; margin-bottom: 5px; text-transform: uppercase; }
.input-group input { 
    width: 100%; background: #0d1117; border: 1px solid #30363d; 
    color: white; padding: 10px; border-radius: 6px; box-sizing: border-box;
}

.game-grid { 
    margin-top: 15px; background: #0d1117; height: 300px; 
    border-radius: 8px; overflow-y: auto; padding: 10px;
}

.game-card {
    padding: 10px; margin-bottom: 8px; background: #1c2128;
    border-radius: 6px; cursor: pointer; border: 1px solid transparent;
}
.game-card:hover { border-color: var(--accent-color); }
.game-card.selected { background: #21262d; border-color: var(--accent-color); }

.progress-bg { background: #30363d; height: 8px; border-radius: 4px; margin: 10px 0; overflow: hidden; }
.progress-fill { height: 100%; width: 0%; background: var(--accent-color); transition: 0.4s ease; }

.warning-text { color: var(--danger); font-size: 11px; margin-top: 5px; display: none; }

.btn-primary {
    width: 100%; padding: 16px; background: var(--accent-color);
    color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer;
}
.btn-primary:disabled { background: #21262d; color: #484f58; cursor: not-allowed; }

.bridge-loader { text-align: center; padding: 20px; color: var(--warning); }
